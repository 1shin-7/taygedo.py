      "skills": [
        {
          "id": "ga_female051_melee",
          "items": [
            {
              "desc": "零挥动武器牵引能量，进行至多<NumGreen>5</>段的连续攻击，造成<Guang>光属性异能伤害</>。",
              "title": "<Title>普通攻击：鉴痕·断</>"
            },
            {
              "desc": "零在空中挥动武器，并迅速下落冲击地面，落地时造成<NumGreen>1</>次范围性的<Guang>光属性异能伤害</>，伤害随下落高度升高而提升，最高提升200%。",
              "title": "<Title>普通攻击：鉴痕·破</>"
            },
            {
              "desc": "触发极限闪避后使用「普通攻击：鉴痕·断」触发。零抓住敌人攻击落空的破绽挥动武器进行反击，造成<NumGreen>1</>次范围性的<Guang>光属性异能伤害</>，并额外扣除一定倾陷值。",
              "title": "<Title>极限反击：一瞬灵感</>"
            },
            {
              "desc": "<Italic>使用剑的方法，是那时唯独能感觉到握于手中的东西。</>"
            }
          ],
          "level": 1,
          "name": "鉴痕",
          "type": "Proactive"
        },
        {
          "id": "ga_female051_skill",
          "items": [
            {
              "desc": "破绽，于此揭露！零连续挥动武器造成<NumGreen>3</>段伤害并跃至空中蓄力，发射一枚「异能炮」，造成<NumGreen>1</>次范围性的<Guang>光属性异能伤害</>，并对命中的第一个等级低于零自身等级的敌人额外造成<NumGreen>1</>次<Guang>光属性异能伤害</>。"
            },
            {
              "desc": "<Italic>超脱现实之景，由斩击浅浅刻画出一角，显现于凭空。</>"
            }
          ],
          "level": 1,
          "name": "铭隙鉴刻",
          "type": "Proactive"
        },
        {
          "id": "ga_female051_ultraskill",
          "items": [
            {
              "desc": "将只有自己能看见的连结奇点之线——以舞动般的剑法一扫俱尽，造成多次范围性的<Guang>光属性异能伤害</>。"
            },
            {
              "desc": "<Italic>感应到的异象奇点，环绕着无形、无声、无味的纽带……以流丽的招式全数切断，只消一瞬。</>"
            }
          ],
          "level": 1,
          "name": "奇零除尽",
